<?xml version="1.0" encoding="utf-8"?>
<tw:TransparentBaseWindow
    x:Class="Morphic.MorphicBar.MorphicBarWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tw="using:Morphic.MorphicBar.TransparentWindow"
    xmlns:local="using:Morphic.MorphicBar"
    xmlns:controls="using:Morphic.MorphicBar.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="MorphicBar">

    <Grid>
        <Border Background="{ThemeResource ThemeAwareBackground}"
                BorderBrush="Black"
                BorderThickness="1"
                CornerRadius="5">
            <Grid x:Name="LayoutGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition x:Name="LogoColumn" Width="Auto"/>
                    <ColumnDefinition x:Name="CloseButtonColumn" Width="25"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition x:Name="LogoRow" Height="0"/>
                </Grid.RowDefinitions>

                <!-- content goes here (column 0, spanning all rows in horizontal orientation) -->

                <!-- Morphic menu logo button (column 1 when horizontal; row 1 when vertical) -->
                <Button x:Name="MorphicMenuButton"
                        Grid.Column="1" Grid.Row="0"
                        Background="Transparent" BorderThickness="0"
                        Padding="0" MinWidth="0" MinHeight="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0,0,5,0"
                        Click="MorphicMenuButton_Click"
                        RightTapped="MorphicMenuButton_RightTapped"
                        AutomationProperties.Name="Morphic Menu">
                    <controls:MorphicMenuLogoViewbox Width="35" Height="46"/>
                </Button>

                <!-- Close button (top-right corner by default (LTR flow direction); top-left corner when RTL flow direction) -->
		<!-- NOTE: the grid column/row changes when the orientation changes; default orientation is horizontal -->
                <Button x:Name="CloseButton"
                        Grid.Column="2" Grid.Row="0"
                        Width="25" Height="20"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="CloseButton_Click"
                        AutomationProperties.Name="Close">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CloseButtonBorder"
                                    Background="{ThemeResource ThemeAwareBackground}"
                                    CornerRadius="0,5,0,0">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="PointerOver">
                                            <VisualState.Setters>
                                                <Setter Target="CloseButtonBorder.Background" Value="#E4142C"/>
                                                <Setter Target="CloseButtonPath.Stroke" Value="White"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <VisualState.Setters>
                                                <Setter Target="CloseButtonBorder.Background" Value="#F1707A"/>
                                                <Setter Target="CloseButtonPath.Stroke" Value="White"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                    <VisualStateGroup x:Name="DirectionStates">
                                        <!-- default is LTR flow direction; when in RTL flow direction, round the top-left corner instead -->
                                        <VisualState x:Name="LeftToRight"/>
                                        <VisualState x:Name="RightToLeft">
                                            <VisualState.StateTriggers>
                                                <local:FlowDirectionTrigger
                                                    Target="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                    Direction="RightToLeft"/>
                                            </VisualState.StateTriggers>
                                            <VisualState.Setters>
                                                <Setter Target="CloseButtonBorder.CornerRadius" Value="5,0,0,0"/>
                                            </VisualState.Setters>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                                <Path x:Name="CloseButtonPath"
                                      Data="M0,0 L10,11 M0,11 L10,0"
                                      Stroke="Gray" StrokeThickness="1"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</tw:TransparentBaseWindow>
