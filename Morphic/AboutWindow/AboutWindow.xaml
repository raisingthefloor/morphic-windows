<?xml version="1.0" encoding="utf-8"?>
<theme:ThemeAwareBaseWindow
    x:Class="Morphic.AboutWindow.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Morphic.AboutWindow"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:theme="using:Morphic.Theme"
    mc:Ignorable="d"
    Title="About Morphic">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <StackPanel Orientation="Vertical"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
        <Image x:Name="LogoImage" Width="50" Height="50" Margin="30,0,30,20"/>

        <TextBlock HorizontalAlignment="Center" FontWeight="Bold" FontSize="13"
                   Text="Morphic for Windows"/>

        <TextBlock HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="12"
                   Text="{x:Bind VersionDisplayString}"/>
        <TextBlock HorizontalAlignment="Center" Margin="0,2,0,0" FontSize="12"
                   Text="{x:Bind BuildDisplayString}"/>

        <TextBlock HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="12"
                   Text="Copyright 2020-2026 Raising the Floor - US, Inc."/>

        <HyperlinkButton HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="9"
                         Content="Learn More about Morphic"
                         Click="LearnMoreHyperlink_Click"/>
    </StackPanel>
</theme:ThemeAwareBaseWindow>
