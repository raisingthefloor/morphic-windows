<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Morphic.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Morphic">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
	    
            <!-- Morphic brand palette for MorphicBar item controls.
                 These are NOT placed inside ThemeDictionaries because they
                 should not follow the system Light/Dark setting. -->
            <SolidColorBrush x:Key="MorphicBarControlBackground"              Color="#008145"/>
            <SolidColorBrush x:Key="MorphicBarControlHoverBackground"         Color="#269562"/>
            <SolidColorBrush x:Key="MorphicBarControlPressedBackground"       Color="#4DA880"/>
            <SolidColorBrush x:Key="MorphicBarControlCheckedBackground"       Color="White"/>
            <SolidColorBrush x:Key="MorphicBarControlCheckedHoverBackground"  Color="#E8E8E8"/>
            <SolidColorBrush x:Key="MorphicBarControlCheckedPressedBackground" Color="#D0D0D0"/>
            <SolidColorBrush x:Key="MorphicBarControlCheckedForeground"       Color="#008145"/>
            <SolidColorBrush x:Key="MorphicBarControlForeground"              Color="White"/>

            <!-- Other app resources here -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="ThemeAwareBackground" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="ThemeAwareForeground" Color="#FF000000"/>
                    <SolidColorBrush x:Key="ThemeAwareMorphicBarMorphieTextForeground" Color="#FF002957"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ThemeAwareBackground" Color="#FF000000"/>
                    <SolidColorBrush x:Key="ThemeAwareForeground" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="ThemeAwareMorphicBarMorphieTextForeground" Color="#FFFFFFFF"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
