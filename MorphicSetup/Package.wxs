<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs" xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Morphic" Manufacturer="Raising the Floor - US, Inc." Version="!(bind.FileVersion.morphic_exe)" UpgradeCode="7d0ee114-79e8-4ff6-b28b-0408551483f5" InstallerVersion="500">

    <Icon Id="MorphicIcon" SourceFile="..\Morphic\Assets\Icons\morphic.ico" />
    <Property Id="ARPPRODUCTICON" Value="MorphicIcon" />

    <MajorUpgrade DowngradeErrorMessage="!(loc.DowngradeError)" />

    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main">
      <ComponentGroupRef Id="MorphicComponents" />
      <ComponentRef Id="ApplicationComponent" />
    </Feature>

    <ui:WixUI Id="WixUI_Minimal" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <UIRef Id="WixUI_ErrorProgressText" />
	
    <Property Id="WINDOWSBUILDNUMBER" Secure="yes">
      <RegistrySearch Id="BuildNumberSearch" Root="HKLM" Key="SOFTWARE\Microsoft\Windows NT\CurrentVersion" Name="CurrentBuildNumber" Type="raw" />
    </Property>
    <Launch Condition="(WINDOWSBUILDNUMBER &gt;= 19045)" Message="!(loc.MinimumOsError)" />
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="!(bind.Property.ProductName)" />
    </StandardDirectory>
    
    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="ApplicationComponent" Guid="8BDA9AF8-9BCC-4B25-8BCF-EE06A3412358">
        <Shortcut 
          Id="MorphicStartMenuShortcut" 
          Name="!(bind.Property.ProductName)"
          Icon="MorphicIcon" 
          Target="[#morphic_exe]"
          WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\Raising the Floor\Morphic" Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>    
  </Fragment>

  <Fragment>
    <ComponentGroup Id="MorphicComponents" Directory="INSTALLFOLDER">
      <Component>
<!--        <File Id="morphic_exe" Source="$(IntermediateOutputPath)\publish\Morphic\Morphic.exe" /> -->
        <File Id="morphic_exe" Source="Morphic.exe" />
      </Component>
      <ComponentGroupRef Id="MorphicSupportComponents" />
    </ComponentGroup>
  </Fragment>
	
</Wix>
